// Prisma schema file for SALA-SYNC SQLite Database

datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  nome      String
  email     String    @unique
  senha     String
  role      String
  setor     String
  setorId   String?
  setorRel  Sector?   @relation(fields: [setorId], references: [id], onDelete: SetNull)
  avatarUrl String?   @default("")
  bookings  Booking[]
}

model Booking {
  id                   String             @id @default(uuid())
  sala                 String
  data                 String
  horaInicial          String
  horaFinal            String
  responsavel          String
  motivo               String
  situacao             String             // "Confirmado", "Finalizado", "Cancelado"
  equipamentos         String
  tempoDeUso           String?            @default("1h")
  pessoas              String?            @default("1")
  usuarioId            String?
  lembreteAntecedencia String?            @default("none")
  lembreteMeio         String?            @default("none")
  recorrenceId         String?
  usuario              User?              @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  equipmentsRequested  BookingEquipment[]
}

model Room {
  id          String   @id @default(uuid())
  name        String   @unique
  capacity    Int
  location    String
  description String?  @default("")
  status      String   @default("Ativa") // "Ativa" or "Inativa"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Legacy compatibility fields
  nome        String?
  capacidade  Int?
  corBg       String?  @default("bg-indigo-50 text-indigo-800 border-indigo-200")
  corTexto    String?  @default("#5B5CEB")
}

model Sector {
  id    String @id @default(uuid())
  nome  String @unique
  users User[]
}

model Equipment {
  id         String             @id @default(uuid())
  nome       String             @unique
  quantidade Int
  ativo      Boolean            @default(true)
  bookings   BookingEquipment[]
}

model BookingEquipment {
  id            String    @id @default(uuid())
  bookingId     String
  equipmentId   String
  quantidade    Int       @default(1)
  booking       Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  equipment     Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([bookingId, equipmentId])
}
